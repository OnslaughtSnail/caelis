{
  "version": 1,
  "default_model": "",
  "permission_mode": "default",
  "sandbox_type": "seatbelt",
  "mainAgent": "copilot",
  "agents": {
    "copilot": {
      "command": "copilot",
      "args": [
        "--acp",
        "--stdio"
      ],
      "stability": "experimental",
      "acp": {
        "model": "high",
        "reasoning_effort": "high"
      }
    }
  }
}
